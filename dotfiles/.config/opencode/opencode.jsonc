{
    "$schema": "https://opencode.ai/config.json",
    "model": "github-copilot/claude-sonnet-4",
    "share": "disabled",
    "autoupdate": false,
    "theme": "dracula",
    "permission": {
        "edit": "allow",
        "bash": {
            // git
            "git status": "allow",
            "git diff": "allow",
            "git log": "allow",

            // read files
            "ls *": "allow",
            "cat *": "allow",
            "bat *": "allow",
            "grep *": "allow",
            "rg *": "allow",
            "tree *": "allow",
            "tail *": "allow",
            "head *": "allow",

            // gradle
            "./gradlew *": "allow",

            // ruby
            "bundle exec rspec *": "allow",

            "*": "ask"
        }
    },
    "lsp": {
        "bash-language-server": {
            "command": [ "bash-language-server", "start" ],
            "extensions": [ ".sh", ".bash" ]
        },
        "nixd": {
            "command": [ "nixd" ],
            "extensions": [ ".nix" ]
        },
        "jdt.language.server": {
            "command": [ "jdtls" ],
            "extensions": [ ".java" ]
        }
    },
    "mcp": {
        //"github": {
        //    "type": "local",
        //    "enabled": true,
        //    "command": [
        //        "docker", "run", "-i", "--rm",
        //        "-e", "GITHUB_PERSONAL_ACCESS_TOKEN",
        //        "ghcr.io/github/github-mcp-server"
        //    ]
        //}
    }
}
