{
  "$schema": "https://opencode.ai/config.json",
  "share": "disabled",
  "autoupdate": false,
  "enabled_providers": [
    "github-copilot"
  ],
  "permission": {
    "edit": "allow",
    "bash": {
      "*": "ask",

      // git
      "git branch*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git merge-base*": "allow",
      "git show*": "allow",
      "git status*": "allow",

      // github
      "gh pr view*": "allow",

      // Utils
      "which *": "allow",
      "echo *": "allow",
      "sleep *": "allow",
      "lsof *": "allow",

      // read files
      "bat *": "allow",
      "cat *": "allow",
      "grep *": "allow",
      "head*": "allow",
      "ls*": "allow",
      "mkdir*": "allow",
      "rg *": "allow",
      "tail*": "allow",
      "tree*": "allow",
      "wc*": "allow",

      // Local
      "curl localhost:8080*": "allow",

      // gradle
      "./gradlew *": "allow",

      // Test
      "npx jest*": "allow",

      // ruby
      "bundle exec rspec *": "allow"
    }
  },
  "lsp": {
    "lua-language-server": {
      "command": [ "lua-language-server" ],
      "extensions": [ "lua" ],
      "initialization": {
        "Lua": {
          "runtime": {
            "version": "LuaJIT"
          }
        }
      }
    },
    "vim-language-server": {
      "command": [ "vim-language-server", "--stdio" ],
      "extensions": [ "vim" ],
      "initialization": {
        "diagnostic": {
          "enable": true
        },
        "indexes": {
          "count": 3,
          "gap": 100,
          "projectRootPatterns": [ "runtime", "nvim", ".git", "autoload", "plugin" ],
          "runtimepath": true
        },
        "isNeovim": true,
        "iskeyword": "@,48-57,_,192-255,-#",
        "runtimepath": "",
        "suggest": {
          "fromRuntimepath": true,
          "fromVimruntime": true
        },
        "vimruntime": ""
      }
    },
    "bash-language-server": {
      "command": [ "bash-language-server", "start" ],
      "extensions": [ ".sh", ".bash" ]
    },
    "yaml-language-server": {
      "command": [ "yaml-language-server", "--stdio" ],
      "extensions": [ ".yml", ".yaml" ],
      "initialization": {
        "redhat": {
          "telemetry": {
            "enabled": false
          }
        },
        "yaml": {
          "schemas": {
            "https://json.schemastore.org/github-workflow.json": "/.github/workflows/*",
            "https://raw.githubusercontent.com/yannh/kubernetes-json-schema/refs/heads/master/v1.32.1-standalone-strict/all.json": "/*.k8s.yaml"
          }
        }
      }
    },
    "docker-language-server": {
      "command": [ "docker-langserver", "--stdio" ],
      "extensions": [ "Dockerfile", "Dockerfile.runtime" ]
    },
    "vscode-json-languageserver": {
      "command": [ "vscode-json-languageserver", "--stdio" ],
      "extensions": [ ".json", ".jsonc" ]
    },
    "nixd": {
      "command": [ "nixd" ],
      "extensions": [ ".nix" ]
    },
    "jdt.language.server": {
      "command": [ "jdtls" ],
      "extensions": [ ".java" ]
    }
  },  
  "mcp": {
    "attlasian": {
      "type": "local",
      "command": [
        "docker",
        "run",
        "-i",
        "--rm",
        "-e", "JIRA_URL",
        "-e", "JIRA_USERNAME",
        "-e", "JIRA_API_TOKEN",
        "ghcr.io/sooperset/mcp-atlassian:latest"
      ],
      "enabled": true,
      "environment": {
        "JIRA_URL": "https://mercadolibre.atlassian.net",
        "JIRA_USERNAME": "emiliano.carletti@mercadolibre.com",
        "JIRA_API_TOKEN": "{env:JIRA_API_TOKEN}"
      }
    },
   // https://web.furycloud.io/ai/mcp/mcps?id=6e2a486e-bab8-43a3-9142-169d4220cdfe
    "furydocs-prod-mcp": {
      "enabled": true,
      "type": "local",
      "command": [
        "mcp-remote-proxy", "https://mcp-furydocs-prod-mcp.melioffice.com/mcp"
      ]
    },
    // https://github.com/melisource/fury_agents-toolkit-hub/blob/main/agents/workflows/mcpconfig/default-mcps.json
    "genai_code_review-mcp": {
      "enabled": true,
      "type": "local",
      "command": [
        "mcp-remote-proxy", "https://genai-code-review-mcp.melioffice.com/mcp"
      ]
    },
    "codeguard-mcp": {
      "enabled": true,
      "type": "local",
      "command": [
        "mcp-remote-proxy", "https://codeguard-mcp.melioffice.com/mcp/"
      ]
    },
    "backend": {
      "enabled": true,
      "type": "local",
      "command": [
        "mcp-remote-proxy", "https://mcp.melioffice.com/namespaces/backend/mcp"
      ]
    },
    "frontender-web-mcp": {
      "enabled": true,
      "type": "local",
      "command": [
        "mcp-remote-proxy", "https://frontender-web-mcp.melioffice.com/mcp"
      ]
    }
  }
}
